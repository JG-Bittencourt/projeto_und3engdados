  <transform>
    <type>TableInput</type>
    <name>Get Departamentos DB</name>
    <sql>SELECT 
   
    t.id_turma AS nk_id_turma,
    t.cod_disc AS nk_codigo_disciplina,
    t.ano,
    t.semestre AS periodo,
    l.mat_professor AS nk_id_professor,
    
    
    u.nome AS nome_professor,
    
   
    COUNT(c.mat_estudante) AS qtd_discentes_matriculados,
    AVG(c.nota) AS media_notas,
    SUM(CASE WHEN c.nota >= 5 THEN 1 ELSE 0 END) AS qtd_aprovados,
    SUM(CASE WHEN c.nota &lt; 5 THEN 1 ELSE 0 END) AS qtd_reprovados

FROM universidade.turma t


INNER JOIN universidade.leciona l ON t.id_turma = l.id_turma


LEFT JOIN universidade.cursa c ON t.id_turma = c.id_turma


INNER JOIN universidade.professor p ON l.mat_professor = p.mat_professor
INNER JOIN universidade.usuario u ON p.cpf = u.cpf


GROUP BY 
    t.id_turma,
    t.cod_disc,
    t.ano,
    t.semestre,
    l.mat_professor,
    u.nome;</sql>
    <limit>0</limit>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <connection>db-crud</connection>
    <lookup/>
    <sql_from_file/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>112</xloc>
      <yloc>528</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
